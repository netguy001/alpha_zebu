# ── AlphaSync Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your values.

# ── Core ────────────────────────────────────────────────────────
APP_NAME=AlphaSync
DEBUG=true
DATABASE_URL=postgresql+asyncpg://alphasync:alphasync@localhost:5432/alphasync
JWT_SECRET_KEY=dev-secret-key-not-for-production
BROKER_ENCRYPTION_KEY=dev-broker-key-not-for-production

# ── Redis (shared live price cache across all user sessions) ────
REDIS_URL=redis://localhost:6379/0

# ── Zebu / MYNT Market Data Feed ────────────────────────────────
ZEBU_WS_URL=wss://go.mynt.in/NorenWSTP/
ZEBU_API_SECRET=

# ── Zebu Broker OAuth (per-user authentication) ────────────────
ZEBU_VENDOR_CODE=
ZEBU_REDIRECT_URI=http://localhost:5173/broker/callback
ZEBU_API_URL=https://go.mynt.in/NorenWClientTP

# ── Simulation ──────────────────────────────────────────────────
SIMULATION_MODE=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BROKER_ENCRYPTION_KEY=alphasync-broker-encryption-default-change-in-production-!!

# ── ZeroLoss Strategy ──────────────────────────────────────────
ZEROLOSS_CONFIDENCE_THRESHOLD=75
ZEROLOSS_SYMBOLS=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK

# ── Simulation ─────────────────────────────────────────────────
SIMULATION_MODE=true

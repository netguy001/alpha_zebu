# ── AlphaSync Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your values.

# ── Core ────────────────────────────────────────────────────────
APP_NAME=AlphaSync
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./alphasync.db
JWT_SECRET_KEY=alphasync-super-secret-key-change-in-production-2024

# ── Market Provider ─────────────────────────────────────────────
# Per-user Zebu sessions — no global provider needed.
# Each user connects via OAuth → gets their own ZebuProvider.

# ── Redis (shared live price cache across all user sessions) ────
REDIS_URL=redis://localhost:6379/0

# ── Zebu Market Data Feed ───────────────────────────────────────
# Per-user sessions created via BrokerSessionManager after OAuth.
ZEBU_WS_URL=wss://ws1.zebull.in/NorenWS/
ZEBU_API_KEY=

# ── Zebu Broker OAuth (per-user authentication) ────────────────
# Required for real broker connections. Users connect their own
# Zebu accounts via the OAuth flow in the frontend.
ZEBU_VENDOR_CODE=
ZEBU_REDIRECT_URI=http://localhost:5173/broker/callback
ZEBU_API_URL=https://api.zebull.in/rest/V3norenapi

# ── Broker Token Encryption (AES-256-GCM) ──────────────────────
# MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BROKER_ENCRYPTION_KEY=alphasync-broker-encryption-default-change-in-production-!!

# ── ZeroLoss Strategy ──────────────────────────────────────────
ZEROLOSS_CONFIDENCE_THRESHOLD=75
ZEROLOSS_SYMBOLS=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK

# ── Simulation ─────────────────────────────────────────────────
SIMULATION_MODE=true
